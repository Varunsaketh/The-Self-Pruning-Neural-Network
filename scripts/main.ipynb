print(f'{"Lambda":>10} | {"Test Acc":>10} | {"Sparsity":>10} | Observation')
print('-'*70)
for i, lam in enumerate(LAMBDA_VALUES):
    r = results[lam]
    obs = ['High accuracy, low sparsity  — classification dominates',
           'Balanced — good accuracy + meaningful pruning',
